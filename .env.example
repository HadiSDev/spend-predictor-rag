# Local vLLM (OpenAI-compatible) endpoint
VLLM_BASE_URL=http://localhost:8000/v1
# CrewAI 1.x uses native providers (no litellm); use the hosted_vllm/ prefix for vLLM
VLLM_MODEL=hosted_vllm/google/gemma-4-E4B-it
VLLM_API_KEY=not-needed
# Bound each LLM call: max_tokens caps generation (prevents runaway/hangs on
# structured output); timeout (seconds) fails a stalled request instead of blocking.
VLLM_MAX_TOKENS=8192
VLLM_TIMEOUT=120

# Embeddings for RAG retrieval
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional path overrides (defaults shown)
# CHART_OF_ACCOUNTS_PATH=data/chart_of_accounts.csv
# INVOICES_DIR=data/invoices
# LEDGER_PATH=output/ledger.csv
# CHROMA_DIR=chroma_db

# Buyer (provided beforehand by the backend). Direct/Indirect is derived from
# the buyer's business context (scraped from the website).
BUYER_NAME=
BUYER_WEBSITE=
# Web context (buyer scrape + product search) cache + search breadth
# WEB_CONTEXT_CACHE_DIR=data/web_cache
PRODUCT_SEARCH_MAX_RESULTS=3
